# Server Configuration
APP_ENV=development
DEBUG=True

# Database (PostgreSQL)
# Local (Docker): postgresql://postgres:postgres@localhost:5432/menubox_ai
# Cloud (Neon/Render): paste the full connection string (include ?sslmode=require)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/menubox_ai

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI Services
ANTHROPIC_API_KEY=your-anthropic-api-key          # REQUIRED — console.anthropic.com

# Restaurant search (optional — search returns 503 without it; photo OCR still works)
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Email / verification (Brevo) — needed for the register -> verify -> login flow
BREVO_API_KEY=your-brevo-api-key
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=MenuBox AI

# Frontend URL (used to build email verification / reset links)
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
